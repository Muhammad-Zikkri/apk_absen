{
  "expo": {
    "name": "PT Putra Andespal Perkasa",
    "slug": "inventaris",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "ios": {
      "infoPlist": {
        "NSCameraUsageDescription": "Kamera digunakan untuk foto selfie absensi",
        "NSLocationWhenInUseUsageDescription": "Lokasi digunakan untuk verifikasi absensi"
      }
    },
    "android": {
      "package": "com.inventaris",
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-camera",
      "expo-location"
    ],
    "extra": {
      "eas": {
        "projectId": "92936f86-7d49-40d5-9a0a-498d946c87b6"
      }
    }
  }
}
